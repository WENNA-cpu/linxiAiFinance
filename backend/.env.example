# 灵析 AI智能投顾助手 - 环境变量配置

# ============================================
# Tushare API配置
# ============================================
# 请访问 https://tushare.pro/ 注册并获取API Token
TUSHARE_TOKEN=your_tushare_token_here

# ============================================
# 数据库配置
# ============================================
# SQLite数据库路径
DATABASE_URL=sqlite:///./lingxi.db

# PostgreSQL配置（可选，生产环境推荐）
# DATABASE_URL=postgresql://user:password@localhost:5432/lingxi

# ============================================
# 安全配置
# ============================================
# JWT密钥（请生成随机字符串）
SECRET_KEY=your-secret-key-here-change-in-production

# 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# AI模型配置
# ============================================
# LSTM模型训练参数
LSTM_EPOCHS=50
LSTM_SEQUENCE_LENGTH=60
LSTM_BATCH_SIZE=32

# 随机森林模型参数
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=15

# 模型保存路径
MODEL_SAVE_PATH=backend/models/saved

# ============================================
# 外部API配置
# ============================================
# OpenAI API（可选，用于增强文本分析）
# OPENAI_API_KEY=your_openai_api_key

# DeepSeek API（投教 AI 问答）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 其他数据源API
# WIND_API_KEY=your_wind_api_key
# CHOICE_API_KEY=your_choice_api_key

# ============================================
# 应用配置
# ============================================
# 调试模式
DEBUG=false

# 日志级别
LOG_LEVEL=INFO

# API请求超时（秒）
API_TIMEOUT=30

# 数据缓存时间（分钟）
CACHE_EXPIRE_MINUTES=5

# ============================================
# 合规配置
# ============================================
# 风险警示阈值
RISK_WARNING_THRESHOLD=0.7

# 最大杠杆倍数限制
MAX_LEVERAGE_LIMIT=3.0

# 集中度风险提示阈值
CONCENTRATION_WARNING_THRESHOLD=0.5
