# 灵析 AI — 秒悟（Meoo）云部署环境变量模板
# 用法：复制为 .env 后填入真实值，详见 DEPLOY.md 第 11 节
#
# 放置位置（二选一，推荐同时配置）：
#   1. 项目根目录：/home/project/.env
#   2. 后端目录：  /home/project/backend/.env
#
# 后端 env_loader 会依次加载上述两个文件。

# ── 必填 ──────────────────────────────────────────

# 行情数据（持仓诊断、周期分析、市场情绪）
TUSHARE_TOKEN=your-tushare-token-here

# 投教问答、诊断追问（DeepSeek）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# 本地加密存储（生产环境务必改为随机强密钥）
# 生成示例：openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-in-production

# ── 推荐 ──────────────────────────────────────────

# SQLite 数据库（秒悟后端工作目录为 backend/ 时使用相对路径即可）
DATABASE_URL=sqlite:///./lingxi.db

# 新模型灰度流量百分比
NEW_MODEL_RATIO=5

# DeepSeek 可选参数（一般保持默认）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── 可选 ──────────────────────────────────────────

# Meoo 平台 AI 服务 Key（Edge Function / LLMClient 使用）
# 当前主流程（投教、诊断追问）走 DeepSeek，此项可暂不填
# 若启用 Meoo AI 或 Edge Function，请在「云服务 → 密钥」中配置同名变量
MEOO_PROJECT_API_KEY=your-meoo-api-key-here

# 运行模式
ENVIRONMENT=production
LOG_LEVEL=INFO
